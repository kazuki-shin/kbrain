{
  "name": "gbrain",
  "version": "0.14.4",
  "description": "Postgres-native personal knowledge brain with hybrid RAG search",
  "type": "module",
  "main": "src/core/index.ts",
  "bin": {
    "gbrain": "src/cli.ts"
  },
  "exports": {
    ".": "./src/core/index.ts",
    "./engine": "./src/core/engine.ts",
    "./types": "./src/core/types.ts",
    "./operations": "./src/core/operations.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile --outfile bin/kbrain src/cli.ts",
    "build:all": "bun build --compile --target=bun-darwin-arm64 --outfile bin/kbrain-darwin-arm64 src/cli.ts && bun build --compile --target=bun-linux-x64 --outfile bin/kbrain-linux-x64 src/cli.ts",
    "build:schema": "bash scripts/build-schema.sh",
    "test": "bun test",
    "test:e2e": "bun test test/e2e/",
    "prepublish:clawhub": "bun run build:all",
    "publish:clawhub": "clawhub package publish . --family bundle-plugin"
  },
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.4.0"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-s3": "^3.1028.0",
    "@electric-sql/pglite": "^0.4.4",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fast-xml-parser": "^5.6.0",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.0",
    "openai": "^4.0.0",
    "pdfjs-dist": "^5.6.205",
    "pgvector": "^0.2.0",
    "playwright": "^1.59.1",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "license": "MIT"
}
